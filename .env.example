# ─────────────────────────────────────────────────────────────────────
# AI Lawyer Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# Use Doppler (production) or direnv (local dev) to manage secrets.
# ─────────────────────────────────────────────────────────────────────

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# CORS — comma-separated list of allowed frontend origins
# =============================================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# SECURITY & AUTH
# =============================================================================
JWT_SECRET=change-me-to-a-random-32-char-string-in-production
JWT_ALGORITHM=HS256

# =============================================================================
# DATABASE — SUPABASE (required in production)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key         # Server-side only — never expose in frontend
SUPABASE_ANON_KEY=your-anon-key            # Safe for frontend
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# CACHE & RATE LIMITING — REDIS (required for production)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AI PROVIDERS
# Two-model setup:
# - Anthropic handles deeper legal reasoning/risk work.
# - OpenRouter uses the OpenAI-compatible client for economy tasks and embeddings.
# =============================================================================
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=AI Lawyer
# OPENROUTER_SITE_URL=http://localhost:8000
OPENAI_API_KEY=sk-or-v1-...
# OPENROUTER_API_KEY=sk-or-v1-...  # Optional alternative to OPENAI_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# MONITORING & OBSERVABILITY (optional but recommended)
# =============================================================================
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# =============================================================================
# MODEL ALIASES (optional — defaults are set in config.py)
# =============================================================================
MODEL_ECONOMY=openai/gpt-4o-mini
MODEL_REASONING=claude-sonnet-4-20250514
MODEL_RESEARCH=openai/gpt-4o-mini
MODEL_VERIFICATION=openai/gpt-4o-mini
MODEL_DOCUMENT=openai/gpt-4o-mini
MODEL_EVIDENCE=openai/gpt-4o-mini
MODEL_RISK=claude-sonnet-4-20250514

# Embeddings use OpenRouter through the OpenAI-compatible endpoint above.
EMBEDDING_MODEL_EN=text-embedding-3-large
EMBEDDING_MODEL_MULTILINGUAL=text-embedding-3-large
EMBEDDING_DIMS=1536

# =============================================================================
# LLM COST CONTROLS
# =============================================================================
LLM_ECONOMY_MODE=true
LLM_FALLBACK_TO_ECONOMY_MODEL=true
LLM_VERIFY_CITATIONS_WITH_LLM=false
LLM_MAX_TOKENS_REASONING=1600
LLM_MAX_TOKENS_DOCUMENT=1400
LLM_MAX_TOKENS_EVIDENCE=1000
LLM_MAX_TOKENS_RISK=1000
LLM_MAX_TOKENS_VERIFICATION=350
LLM_MAX_TOKENS_DRAFT=1500
LLM_MAX_TOKENS_ABSOLUTE=1800

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUERY_PER_MINUTE=10
RATE_LIMIT_STREAM_PER_MINUTE=30
RATE_LIMIT_DOCUMENT_PER_MINUTE=5
RATE_LIMIT_EVIDENCE_PER_MINUTE=5
RATE_LIMIT_BACKEND=auto

# =============================================================================
# AGENTIC RAG
# =============================================================================
RAG_CHUNK_MAX_CHARS=2600
RAG_CHUNK_OVERLAP_CHARS=350
RAG_EMBEDDING_BATCH_SIZE=48
RAG_PLAN_MAX_QUERIES=3
REASONING_CONTEXT_TOP_K=6
REASONING_CONTEXT_CHUNK_CHARS=1200
CASE_ANALYSIS_MIN_FACT_CHARS=120

# =============================================================================
# FILE UPLOADS
# =============================================================================
# 50MB supports law-code PDFs around 50,000KB; request body allows multipart overhead.
MAX_UPLOAD_SIZE_MB=50
MAX_REQUEST_BODY_MB=55
URL_INGEST_MAX_DOCUMENTS=10
PDF_OCR_ENABLED=true
PDF_DETECT_GARBLED_TEXT=true
PDF_OCR_MAX_PAGES=0
PDF_OCR_DPI=300
PDF_OCR_LANGUAGES=lao+eng
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSDATA_PREFIX=
